id: requirements-refinement
version: 1.3.0
name: Requirements Refinement
description: "Guided elicitation of the workflow specification across purpose, activities, checkpoints, artifacts, variables, techniques, and rules."
required: true
rules[3]:
  - "One question at a time — present each checkpoint independently and wait for the response before proceeding"
  - "Show what was captured so far before asking the next question"
  - "Do not assume answers — if the user's description is ambiguous, ask for clarification"
steps[1]:
  - id: elicitation
    technique: elicitation
checkpoints[8]:
  - id: purpose-confirmed
    name: Purpose Confirmation
    message: "Here is the workflow purpose and domain I've captured. Is this accurate?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, that's right"
        description: Purpose is accurately captured
      - id: refine
        label: "Needs refinement"
        description: "Purpose statement requires clarification before proceeding."
  - id: activities-confirmed
    name: Activity List Confirmation
    message: "Here is the activity list I've captured with names, purposes, and expected artifacts. Is this complete?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, this is complete"
        description: Activity list is accurate and complete
      - id: refine
        label: "Needs changes"
        description: "Activity list requires additions, removals, or modifications."
  - id: model-confirmed
    name: Activity Model Confirmation
    condition:
      type: simple
      variable: is_update_mode
      operator: "!="
      value: true
    message: "Based on our discussion, this workflow uses a {sequential/independent} activity model. Is this correct?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, correct model"
        description: Activity model is correct
      - id: change
        label: "Change model"
        description: "Activity model needs to be switched to the alternative."
  - id: checkpoints-confirmed
    name: Checkpoints Confirmation
    message: "Here are the checkpoints I've defined for each activity with their options and effects. Do these cover all necessary user decision points?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, checkpoints are complete"
        description: Checkpoint coverage is adequate
      - id: refine
        label: "Needs changes"
        description: "Checkpoint set requires additions, removals, or modifications."
  - id: artifacts-confirmed
    name: Artifacts Confirmation
    message: "Here are the artifacts each activity produces. Is this complete?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, artifacts are complete"
        description: Artifact list is accurate
      - id: refine
        label: "Needs changes"
        description: "Artifact set requires additions, removals, or modifications."
  - id: variables-confirmed
    name: Variables Confirmation
    condition:
      type: simple
      variable: is_update_mode
      operator: "!="
      value: true
    message: "Here are the workflow variables I've identified for state tracking. Is this complete?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, variables are complete"
        description: Variable list is accurate
      - id: refine
        label: "Needs changes"
        description: "Variable set requires additions, removals, or modifications."
  - id: techniques-confirmed
    name: Techniques Confirmation
    condition:
      type: simple
      variable: is_update_mode
      operator: "!="
      value: true
    message: "Here are the techniques needed by this workflow. Is this complete?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, techniques are complete"
        description: Technique list is accurate
      - id: refine
        label: "Needs changes"
        description: "Technique set requires additions, removals, or modifications."
  - id: rules-confirmed
    name: Rules Confirmation
    message: "Here are the workflow rules I've captured, each marked as text-only or structurally enforced. Is this complete?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, rules are complete"
        description: Rule list is accurate
        effect:
          setVariable:
            requirements_confirmed: true
      - id: refine
        label: "Needs changes"
        description: "Rule set requires additions, removals, or modifications."
transitions[2]:
  - to: impact-analysis
    condition:
      type: simple
      variable: is_update_mode
      operator: ==
      value: true
  - to: pattern-analysis
    isDefault: true
outcome[1]:
  - A complete workflow specification — purpose, activities, checkpoints, artifacts, variables, techniques, and rules — that the user has confirmed across every dimension, so drafting proceeds from settled requirements rather than open questions
