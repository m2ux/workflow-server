# Slack App (Socket Mode)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# Cursor CLI
CURSOR_API_KEY=key_your-cursor-api-key
CURSOR_AGENT_BINARY=agent

# Repository
REPO_PATH=/path/to/midnight-agent-eng
WORKTREE_BASE_DIR=/path/to/worktrees

# MCP Servers (JSON object, same format as .cursor/mcp.json mcpServers)
# Each key is a server name, value is { command, args, env }
MCP_SERVERS_JSON={}
