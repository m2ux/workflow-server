# Copy to `.env` (gitignored) and adjust paths for your machine:
#   cp .env.example .env
#   ./scripts/init-local-env.sh   # fills absolute paths from this checkout
#
# Used by:
#   - MCP clients (export these into the environment Cursor/Claude inherits)
#   - docker compose (HOST_* binds; CONTAINER_* in-container targets)
#
# Cursor expands ${env:NAME} from the IDE process environment — not from
# `.env` alone. After editing `.env`, either:
#   source .env && export WORKFLOW_SERVER_MCP_URL CONCEPT_RAG_ENTRY CONCEPT_RAG_INDEX
# or launch Cursor from a shell that has already sourced `.env`, or set the
# vars in your desktop/session environment.

# =============================================================================
# MCP client → HTTP workflow-server (mcp-remote)
# =============================================================================
# Full MCP endpoint URL (compose default publish is host port 3000).
WORKFLOW_SERVER_MCP_URL=http://127.0.0.1:3000/mcp

# Optional companion MCP servers (only if those entries stay in .mcp.json)
# CONCEPT_RAG_ENTRY=
# CONCEPT_RAG_INDEX=

# =============================================================================
# Server process paths (when starting the HTTP server / compose container)
# =============================================================================
# Install root (default: ~/.local/share/workflow-server). Used with --repo.
# WORKFLOW_SERVER_INSTALL_DIR=

# Workspace / worktree root (default when empty: $INSTALL/workspace).
WORKFLOW_WORKSPACE=

# Engineering root (default when empty: $INSTALL/engineering).
# WORKFLOW_SERVER_ENGINEERING_DIR=

# Optional alias for workspace root (containers often use this name instead)
# WORKTREE_ROOT=

# Optional process pin to one owner/repo (stdio single-tenant). Prefer passing
# repo at start_session when using Docker multi-root + init-repo.
# WORKFLOW_SERVER_REPO=m2ux/my-project

# Workflow definitions and schemas on the host (absolute paths recommended)
WORKFLOW_DIR=
SCHEMAS_DIR=

# Optional planning layout override
# Legacy single-root default: .engineering/artifacts/planning
# Repo / engineering-checkout default: artifacts/planning
# PLANNING_SLUG=artifacts/planning

# Optional: directory for the session HMAC key file `secret` (default: ~/.workflow-server).
# Docker start.sh / compose set this to /var/lib/workflow-server/state on a bind mount.
# WORKFLOW_SERVER_KEY_DIR=
# WORKFLOW_SERVER_STATE_DIR=

# =============================================================================
# Docker Compose — host bind sources (paths on the machine running compose)
# =============================================================================
# Host binds (install.sh defaults: $INSTALL/workspace and $INSTALL/engineering)
HOST_WORKTREE_ROOT=
HOST_ENGINEERING_ROOT=
HOST_WORKFLOWS_DIR=./workflows
HOST_SCHEMAS_DIR=./schemas
# Durable HMAC key on the host (install.sh default: $INSTALL/state)
HOST_STATE_DIR=
HOST_PORT=3000

# =============================================================================
# Docker Compose — in-container paths (volume targets + server env inside image)
# Must NOT reuse WORKFLOW_DIR / WORKFLOW_WORKSPACE from the host section above.
# =============================================================================
CONTAINER_INSTALL_DIR=/var/lib/workflow-server
CONTAINER_WORKTREE_ROOT=/var/lib/workflow-server/workspace
CONTAINER_ENGINEERING_ROOT=/var/lib/workflow-server/engineering
CONTAINER_STATE_DIR=/var/lib/workflow-server/state
CONTAINER_WORKFLOW_DIR=/app/workflows
CONTAINER_SCHEMAS_DIR=/app/schemas

# Transport inside the container (compose defaults)
TRANSPORT=http
HOST=0.0.0.0
PORT=3000
