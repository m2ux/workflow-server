id: start
version: 1.3.0
name: Start Security Vulnerability Remediation
description: "Initialize a high-sensitivity security fix."
required: true
steps[15]:
  - kind: action
    id: announce-start
    actions[1]:
      - action: log
        message: "ENTERING SECURITY VULNERABILITY MODE - ISOLATION ACTIVE"
  - kind: action
    id: set-security-mode
    actions[1]:
      - action: set
        target: is_sec_vuln_mode
        value: true
  - kind: technique
    id: collect-security-inputs
    technique: security-setup::collect-security-inputs
  - kind: checkpoint
    id: sec-vuln-url-input
    condition:
      type: simple
      variable: sec_vuln_url
      operator: notExists
    message: "Please provide the private security advisory URL:"
    blocking: true
    options[1]:
      - id: provided
        label: "URL Provided"
        description: "Proceed with this URL"
  - kind: action
    id: resolve-target
    actions[1]:
      - action: validate
        target: "target_path exists"
        message: "Target directory not found at the supplied target_path"
  - kind: checkpoint
    id: private-fork-url-input
    condition:
      type: simple
      variable: private_fork_url
      operator: notExists
    message: "Please provide the private fork URL for the security vulnerability fix:"
    blocking: true
    options[1]:
      - id: provided
        label: "URL Provided"
        description: "Proceed with this URL"
  - kind: technique
    id: configure-sec-vuln-remote
    technique: security-setup::configure-security-remote
  - kind: checkpoint
    id: confirm-security-remote
    message: "CRITICAL: Isolation check. Confirm that the 'security' remote is configured and points to a PRIVATE repository. Is 'git remote -v' output correct for 'security'?"
    blocking: true
    options[2]:
      - id: confirmed
        label: "Yes, security remote is private"
        description: "Confirmed security remote is correctly configured for isolation"
      - id: wrong-remote
        label: "No, fix remote"
        description: "Remote is incorrect; must be fixed before proceeding"
  - kind: checkpoint
    id: short-id-input
    condition:
      type: simple
      variable: short_id
      operator: notExists
    message: "Please provide a short advisory slug for the security branch name (e.g. cve-2026-1234):"
    blocking: true
    options[1]:
      - id: provided
        label: "Short ID Provided"
        description: "Proceed with this slug"
  - kind: technique
    id: initialize-security-branch
    technique: security-setup::initialize-security-branch
  - kind: checkpoint
    id: verify-isolation
    message: "The 'security' remote and local branch are configured, and no public PR or Issue will be created. Is the private remote URL {sec_vuln_url} correct and authorized?"
    blocking: true
    options[2]:
      - id: authorized
        label: "Yes, proceed"
        description: "Confirmed private remote and isolation"
      - id: cancel
        label: "No, abort"
        description: "Stop immediately"
  - kind: technique
    id: initialize-planning-folder
    technique: security-setup::initialize-planning-folder
  - kind: technique
    id: present-security-overview
    technique: security-setup::present-security-overview
  - kind: technique
    id: finalize-setup
    technique: security-setup::verify-origin-untracked
  - kind: action
    id: announce-completion
    actions[1]:
      - action: log
        message: "Security initialization complete. Public disclosure paths disabled."
transitions[1]:
  - to: design-philosophy
    isDefault: true
outcome[4]:
  - "The workflow is locked into isolation: every public disclosure path is disabled for the rest of the fix"
  - "All git operations have a private-only destination — the fix cannot be pushed to a public repository"
  - "The fix develops on a dedicated advisory branch off the private fork, never touching a public branch"
  - "Planning happens entirely off any public surface — no PR or Issue link is ever recorded"
