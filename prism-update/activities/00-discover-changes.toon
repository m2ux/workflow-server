id: discover-changes
version: 1.0.0
name: Discover Changes
description: "Diff upstream prisms directory against current workflow resources. Categorize each prism as new, modified, renamed, or deleted. Classify new prisms by family and determine the next available resource index."
problem: Need to understand what changed upstream before importing
skills:
  primary: diff-upstream
steps[5]:
  - id: list-upstream
    name: List upstream prisms
    description: "Enumerate all .md files in upstream_path, filtering out exclusions."
  - id: list-current
    name: List current resources
    description: "Enumerate all resource files, extracting index prefix and prism name from each."
  - id: diff-and-categorize
    name: Diff and categorize
    description: "Compare the two file lists. Categorize each upstream file as new, modified, renamed, or deleted."
  - id: classify-new
    name: Classify new prisms
    description: "Read each new prism's YAML frontmatter. Extract metadata and classify into family."
  - id: determine-next-index
    name: Determine next index
    description: "Set next_index to highest existing resource index + 1."
    actions[1]:
      - action: set
        target: next_index

transitions[1]:
  - to: review-changes
    isDefault: true

estimatedTime: "3-5m"

outcome[3]:
  - "changes variable populated with categorized diff"
  - "New prisms classified by family with metadata"
  - "next_index determined"

context_to_preserve[3]:
  - "changes — categorized diff result"
  - "next_index — next available resource index"
  - "exclusions — user-specified exclusions"
