{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "session-file",
  "description": "Server-managed session file (session.json) — canonical session state owned by the workflow server.",
  "$ref": "#/definitions/session-file",
  "definitions": {
    "session-file": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "sessionIndex": {
          "type": "string",
          "pattern": "^[A-Z2-7]{6}$"
        },
        "workflowId": {
          "type": "string",
          "minLength": 1
        },
        "workflowVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "agentId": {
          "type": "string",
          "minLength": 1
        },
        "seq": {
          "type": "integer",
          "minimum": 0
        },
        "ts": {
          "type": "integer",
          "minimum": 0
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "currentActivity": {
          "type": "string",
          "default": ""
        },
        "currentTechnique": {
          "type": "string",
          "default": ""
        },
        "condition": {
          "type": "string",
          "default": ""
        },
        "activeCheckpoint": {
          "type": "object",
          "properties": {
            "checkpointId": {
              "type": "string",
              "minLength": 1
            },
            "activityId": {
              "type": "string",
              "minLength": 1
            },
            "yieldedAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "checkpointId",
            "activityId",
            "yieldedAt"
          ],
          "additionalProperties": false
        },
        "variables": {
          "type": "object",
          "additionalProperties": {},
          "default": {}
        },
        "completedActivities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "skippedActivities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "checkpointResponses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "optionId": {
                "type": "string"
              },
              "respondedAt": {
                "type": "string",
                "format": "date-time"
              },
              "effects": {
                "type": "object",
                "properties": {
                  "variablesSet": {
                    "type": "object",
                    "additionalProperties": {}
                  },
                  "transitionedTo": {
                    "type": "string"
                  },
                  "activitiesSkipped": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "optionId",
              "respondedAt"
            ],
            "additionalProperties": false
          },
          "default": {}
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "type": {
                "type": "string",
                "enum": [
                  "workflow_started",
                  "workflow_completed",
                  "workflow_aborted",
                  "workflow_triggered",
                  "workflow_returned",
                  "workflow_suspended",
                  "activity_entered",
                  "activity_exited",
                  "activity_skipped",
                  "step_started",
                  "step_completed",
                  "checkpoint_reached",
                  "checkpoint_response",
                  "checkpoint_replayed",
                  "decision_reached",
                  "decision_branch_taken",
                  "loop_started",
                  "loop_iteration",
                  "loop_completed",
                  "loop_break",
                  "variable_set",
                  "error"
                ]
              },
              "activity": {
                "type": "string"
              },
              "step": {
                "type": "integer",
                "minimum": 1
              },
              "checkpoint": {
                "type": "string"
              },
              "decision": {
                "type": "string"
              },
              "loop": {
                "type": "string"
              },
              "data": {
                "type": "object",
                "additionalProperties": {}
              },
              "error": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string"
                  }
                },
                "required": [
                  "message"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "timestamp",
              "type"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "status": {
          "type": "string",
          "enum": [
            "running",
            "completed",
            "aborted"
          ],
          "default": "running"
        },
        "triggeredWorkflows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "workflowId": {
                "type": "string",
                "minLength": 1
              },
              "sessionIndex": {
                "type": "string",
                "pattern": "^[A-Z2-7]{6}$"
              },
              "triggeredAt": {
                "type": "string",
                "format": "date-time"
              },
              "triggeredFrom": {
                "type": "object",
                "properties": {
                  "activityId": {
                    "type": "string"
                  },
                  "stepIndex": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "required": [
                  "activityId"
                ],
                "additionalProperties": false
              },
              "status": {
                "type": "string",
                "enum": [
                  "running",
                  "completed",
                  "aborted",
                  "error"
                ]
              },
              "completedAt": {
                "type": "string",
                "format": "date-time"
              },
              "returnedContext": {
                "type": "object",
                "additionalProperties": {}
              },
              "state": {
                "$ref": "#/definitions/session-file"
              }
            },
            "required": [
              "workflowId",
              "sessionIndex",
              "triggeredAt",
              "triggeredFrom",
              "status"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "planningFolderPath": {
          "type": "string"
        },
        "contextMode": {
          "type": "string",
          "enum": [
            "persistent",
            "fresh"
          ]
        },
        "deliveredContent": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "parentSession": {
          "$ref": "#/definitions/session-file"
        }
      },
      "required": [
        "schemaVersion",
        "sessionIndex",
        "workflowId",
        "workflowVersion",
        "agentId",
        "seq",
        "ts",
        "startedAt"
      ],
      "additionalProperties": false
    }
  }
}
