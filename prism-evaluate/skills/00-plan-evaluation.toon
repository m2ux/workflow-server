id: plan-evaluation
version: 1.0.0
capability: Classify an evaluation target, derive or validate evaluation dimensions, and map each dimension to prism analytical lens configurations

description: "Given a target path and evaluation description, classify the target type, derive evaluation dimensions appropriate to the target and goals (or validate user-supplied dimensions), survey the target structure to inform lens selection, map each dimension to prism pipeline modes and lenses, group dimensions by pipeline mode for execution, and produce an evaluation plan artifact."

inputs[4]:
  - id: target_path
    description: "Path to the document, proposal, codebase, or artifact set to evaluate"
    required: true
  - id: evaluation_description
    description: "User's description of what to evaluate, evaluation goals, focus areas, and concerns"
    required: true
  - id: output_path
    description: "Directory to write the evaluation plan artifact"
    required: true
  - id: lens_overrides
    description: "Optional user-specified lens overrides per dimension. Keys are dimension names, values are { pipeline_mode, lenses }"
    required: false

protocol:
  classify-target[5]:
    - "Examine target_path to determine the target type"
    - "'document' — target_path is a single file (markdown, PDF, text)"
    - "'document-set' — target_path is a directory containing documents without build infrastructure"
    - "'codebase' — target_path is a directory containing source code with build files (Cargo.toml, package.json, go.mod, pyproject.toml)"
    - "'mixed' — target_path contains both code and substantive documentation"

  derive-dimensions[4]:
    - "If the user supplied dimensions, validate them: each must have a name and description. Proceed to survey-target."
    - "If no dimensions supplied, load resource 00 (default-dimensions) and select the dimension set matching the target_type. Each dimension object has: { name, description, focus_areas (array of specific aspects to examine) }."
    - "For target types not covered by the resource defaults, infer dimensions from the evaluation_description. Each dimension should represent an independent analytical axis."
    - "Present derived dimensions for user confirmation during the scope-definition checkpoint"

  survey-target[8]:
    - "List files and directories at the top level of target_path"
    - "For document/document-set targets: inventory all documents, identify their topics, structure, and cross-references between documents. Note total word count or section count."
    - "For codebase targets: identify the build system, enumerate modules/packages, count lines of code per module. Identify test directories."
    - "For mixed targets: apply both document and code surveys"
    - "If GitNexus is available (check via gitnexus_list_repos) and target is a codebase: use gitnexus_query to discover functional areas and community clusters for better module classification"
    - "Read enough of the target content to understand its scope, key topics, claims, and structure — this informs dimension-specific analysis_focus values"
    - "For proposal documents: identify the major sections, stated goals, key claims, architectural decisions, resource assumptions, and timeline commitments"
    - "Record: target_type, target_summary, structure_inventory (sections or modules with sizes), key_topics"

  map-dimensions-to-lenses[6]:
    - "Load resource 01 (dimension-lens-mapping) for the standard and custom mapping tables, output subdirectory conventions, and pipeline mode selection guidance."
    - "For each dimension, match against the standard mappings table first. If no standard mapping matches, use the custom dimension mappings table."
    - "If lens_overrides contains an entry for a dimension name, use the override values instead of the derived mapping"
    - "For each dimension, compose a dimension-specific analysis_focus string: a focused description of what to examine within this dimension, referencing specific target content discovered during survey-target. This MUST NOT be a bare label like 'security audit' or 'audit' — it must be substantive guidance."
    - "Assign each dimension an output_subdir per the conventions in resource 01."
    - "Record dimension_plan: array of { dimension (name), pipeline_mode, lenses (array of resource indices), analysis_focus, output_subdir }"

  group-for-execution[4]:
    - "Group dimensions that share the same pipeline mode into execution groups"
    - "Full-prism dimensions each get their own group (full-prism runs the 3-pass pipeline and cannot be combined)"
    - "Portfolio dimensions can be combined: all portfolio lenses run in a single prism trigger with pipeline_mode 'portfolio' and selected_lenses merging all lens indices. Each lens writes to its own artifact file within the output_subdir."
    - "Record execution_groups: array of { pipeline_mode, lenses, dimensions (array of names), analysis_focus (combined), output_subdir }"

  write-evaluation-plan[4]:
    - "Compose a human-readable evaluation plan document"
    - "Section 1: Target Overview — target type, structure summary, key topics"
    - "Section 2: Dimension Plan — table mapping each dimension to pipeline mode, lenses, focus areas, and output location"
    - "Section 3: Execution Groups — how dimensions are grouped for prism triggering, execution order, estimated sub-agent dispatches"

output[2]:
  - id: evaluation-plan
    description: "The composed evaluation plan document"
    artifact:
      name: "evaluation-plan.md"
    components:
      target_overview: "Target classification and structure summary"
      dimension_plan: "Per-dimension lens mapping and analysis focus"
      execution_groups: "Grouped execution strategy"
  - id: dimension-plan
    description: "Machine-readable dimension-to-lens mapping for the execute-analysis activity"
    components:
      plan: "Array of { dimension, pipeline_mode, lenses, analysis_focus, output_subdir }"

tools:
  glob:
    when: "Surveying target structure"
    usage: "Discover files, directories, and project/document markers"
  read_file:
    when: "Reading documents, build configuration, or source files for structural understanding"
    usage: "Examine target content to inform analysis focus values"
  grep:
    when: "Scanning for patterns relevant to specific dimensions"
    usage: "Search for claims, assumptions, architectural decisions, or other dimension-relevant content"
  write_file:
    when: "Writing the evaluation plan artifact"
    params: "path: {output_path}/evaluation-plan.md"
  gitnexus_list_repos:
    when: "Checking whether GitNexus has indexed the target (codebase targets only)"
    returns: "List of indexed repositories with names and paths"
  gitnexus_query:
    when: "Discovering functional areas and module clusters for codebase targets"
    params: "query: relevant to evaluation dimensions"
    returns: "Processes ranked by relevance with symbols and file locations"

resources[2]:
  - "00"
  - "01"

errors:
  empty_target:
    cause: "Target path contains no analysable files"
    recovery: "Verify the path is correct. Check if the target is in a different location."
  no_relevant_dimensions:
    cause: "Cannot derive meaningful evaluation dimensions from the description and target"
    recovery: "Ask the user to provide explicit dimensions or refine the evaluation description."
  unmappable_dimension:
    cause: "A user-supplied dimension does not map to any known prism lens pattern"
    recovery: "Suggest the closest lens match from the goal-mapping matrix. Ask the user to confirm or provide a lens_override for this dimension."
