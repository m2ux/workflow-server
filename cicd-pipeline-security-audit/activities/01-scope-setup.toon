id: scope-setup
version: 1.0.0
name: Scope Setup
description: "Confirm target submodules, discover all GitHub Actions workflow files, create planning folder with START-HERE.md. Fully automated — no user checkpoints."
problem: The audit requires confirmed targets, a complete workflow file inventory, and an organized artifact folder before scanning begins.
recognition[4]:
  - start cicd audit
  - audit pipelines
  - scan github actions
  - cicd security audit
skills:
  supporting[1]:
    - execute-cicd-audit
required: true
estimatedTime: 5-10m
rules[4]:
  - "At least one target submodule MUST be specified in the initial request, or 'all' to scan every submodule with .github/workflows/"
  - "The planning folder naming pattern: YYYY-MM-DD-cicd-security-audit"
  - "Workflow file discovery must include both .yml and .yaml extensions"
  - "Record each submodule's workflow file count for dispatch planning"
entryActions[1]{action,message}:
  log,Starting CI/CD pipeline security audit scope setup
steps[5]:
  - id: confirm-targets
    name: Confirm Target Submodules
    description: "Extract target submodules from request. If 'all' specified, enumerate every submodule containing .github/workflows/. Validate each path exists."
  - id: discover-workflows
    name: Discover Workflow Files
    skill: inventory-workflows
    description: "For each target submodule, enumerate all .github/workflows/*.yml and .github/workflows/*.yaml files. Record total count."
  - id: discover-ai-configs
    name: Discover AI Configuration Files
    description: "For each target submodule, check for CLAUDE.md, AGENTS.md, .cursorrules, .cursor/rules/, and similar AI agent config files. Record paths for P6 detection."
  - id: create-planning-folder
    name: Create Planning Folder
    description: "Create planning folder with START-HERE.md containing audit scope, methodology, target inventory, and artifact index."
  - id: record-codeowners
    name: Record CODEOWNERS Presence
    description: "For each target submodule, check whether a CODEOWNERS file exists and record its path. This informs P6 (AI config protection) detection."
transitions[1]{to,isDefault}:
  reconnaissance,true
exitActions[1]{action,message}:
  log,Scope setup complete — targets confirmed and workflow inventory built
outcome[5]:
  - Target submodules confirmed and validated
  - All workflow files discovered and counted
  - AI configuration files inventoried
  - CODEOWNERS presence recorded per submodule
  - Planning folder created with START-HERE.md
context_to_preserve[5]:
  - target_submodules - Comma-separated list of submodule paths in scope
  - planning_folder_path - Path to planning artifacts folder
  - workflow_file_count - Total workflow files discovered
  - submodule_count - Number of submodules in scope
  - ai_config_inventory - AI config files found per submodule
artifacts[1]:
  - id: start-here
    name: START-HERE.md
    location: planning
    description: "Session overview with audit scope, methodology, target inventory, and artifact index"
