{
  "mcpServers": {
    "rust-docs-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "Rust:https://github.com/m2ux/llms/blob/main/rust-llms.txt",
        "--transport",
        "stdio",
        "--allowed-domains",
        "*"
      ]
    },
    "concept-rag": {
      "command": "node",
      "args": [
        "${env:CONCEPT_RAG_ENTRY}",
        "${env:CONCEPT_RAG_INDEX}"
      ]
    },
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ]
    },
    "workflow-server": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "${env:WORKFLOW_SERVER_MCP_URL}"
      ]
    },
    "gitnexus": {
      "command": "/usr/local/bin/gitnexus",
      "args": [
        "mcp"
      ]
    }
  }
}
