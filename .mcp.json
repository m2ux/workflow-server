{
  "mcpServers": {
    "rust-docs-mcp": {
      "command": "uvx",
      "args": [
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "Rust:https://github.com/m2ux/llms/blob/main/rust-llms.txt",
        "--transport",
        "stdio",
        "--allowed-domains",
        "*"
      ]
    },
    "concept-rag": {
      "command": "node",
      "args": [
        "/home/mike1/projects/main/concept-rag/dist/conceptual_index.js",
        "/home/mike1/.concept_rag"
      ]
    },
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ]
    },
    "workflow-server": {
      "command": "node",
      "args": [
        "/home/mike1/projects/main/workflow-server/dist/index.js",
        "--workspace=/home/mike1/projects/work",
        "--workflow-dir=/home/mike1/projects/main/workflow-server/workflows"
      ]
    },
    "gitnexus": {
      "command": "/usr/local/bin/gitnexus",
      "args": [
        "mcp"
      ]
    }
  }
}
