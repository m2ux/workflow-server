id: resolve-target
version: 3.0.0
name: Resolve Target
description: "Detect the target repository structure (regular directory vs. submodule monorepo) and resolve target_path. Sets is_monorepo and target_path for downstream activities that perform git operations on the user's codebase."
problem: Workflows that operate on a target codebase need to know whether the working directory is a regular repo or a submodule monorepo, and which submodule is the target
required: true
estimatedTime: 1-2m
operations[2]:
  - "version-control::detect-repo-type"
  - "version-control::list-submodules"
rules[1]:
  - "target_path MUST resolve to a directory containing a working git tree"
entryActions[1]:
  - action: log
    message: "Resolving target repository structure"
steps[3]:
  - id: detect-monorepo
    name: Detect Repository Type
    operation: "version-control::detect-repo-type"
  - id: list-submodules
    name: List Submodules
    operation: "version-control::list-submodules"
    condition:
      type: simple
      variable: is_monorepo
      operator: "=="
      value: true
  - id: capture-submodule-target
    name: Capture Submodule Target
    description: "Ask the user to select a submodule from the listed entries. Set target_path to the chosen path."
    condition:
      type: simple
      variable: is_monorepo
      operator: "=="
      value: true
checkpoints[1]:
  - id: repo-type-confirmed
    name: Repository Type Confirmation
    message: "Is this a regular repository or a submodule monorepo?"
    options[2]:
      - id: regular
        label: Regular repository
        description: Single-repo project; target_path will be the repository root
        effect:
          setVariable:
            is_monorepo: false
            target_path: "."
      - id: monorepo
        label: Submodule monorepo
        description: Parent repo with submodules; the next step will list submodules for selection
        effect:
          setVariable:
            is_monorepo: true
transitions[1]:
  - to: dispatch-client-workflow
    isDefault: true
outcome[2]:
  - Repository type confirmed by the user
  - target_path resolved to '.' (regular) or a submodule path (monorepo)
context_to_preserve[2]:
  - is_monorepo - Whether the target is a submodule monorepo
  - target_path - Resolved target directory for git operations
