id: validate
version: 3.0.0
name: Verify & Validate Design
description: "Validate the implementation by running tests, build, format, and lint via cargo-operations (Rust/Substrate) or project-equivalent commands, then aggregate results via validate-build. Test suite quality was reviewed at the implement phase."
problem: User needs to validate the implementation passes all tests
recognition[3]:
  - validate implementation
  - run tests
  - verify build
required: true
estimatedTime: 15-30m
operations[8]:
  - "cargo-operations::test"
  - "cargo-operations::check"
  - "cargo-operations::build-release"
  - "cargo-operations::fmt-check"
  - "cargo-operations::clippy"
  - "validate-build::analyze-failure"
  - "validate-build::apply-fix"
  - "validate-build::aggregate-results"
steps[10]:
  - id: run-tests
    name: Run all tests
    description: "cargo-operations::test(scope: '--workspace')"
    when: "project_type == 'rust-substrate'"
  - id: verify-build
    name: Verify build succeeds
    description: "cargo-operations::check(scope: '--workspace')"
    when: "project_type == 'rust-substrate'"
  - id: check-format
    name: Check formatting
    description: "cargo-operations::fmt-check(scope: '--all')"
    when: "project_type == 'rust-substrate'"
  - id: check-lint
    name: Check for linter errors
    description: "cargo-operations::clippy(scope: '--workspace')"
    when: "project_type == 'rust-substrate'"
  - id: aggregate-results
    name: Aggregate validation results
    description: "validate-build::aggregate-results(test_results: {test_status}, build_status: {check_status}, format_status: {fmt_status}, lint_results: {clippy_status})"
  - id: evaluate-results
    name: Evaluate validation results
    description: "Read validation_results from aggregate-results. Set has_failures and validation_passed from it."
    actions[2]:
      - action: set
        target: has_failures
        value: true
        message: "true when validation_results.validation_passed is false; false otherwise"
      - action: set
        target: validation_passed
        value: true
        message: "Mirrors validation_results.validation_passed"
  - id: document-failures
    name: Document Failures as Findings
    description: "Document all test/build/lint failures as review findings with severity (critical for test failures, high for build failures). Do NOT attempt to fix."
    condition:
      type: simple
      variable: is_review_mode
      operator: "=="
      value: true
  - id: assess-test-coverage
    name: Assess Test Coverage
    description: "Evaluate whether the tests added are sufficient for the changes made. Check coverage of edge cases and error paths."
    condition:
      type: simple
      variable: is_review_mode
      operator: "=="
      value: true
  - id: fix-failures
    name: Fix any failures
    description: "Enter the fix-revalidate-cycle loop. Each iteration calls validate-build::analyze-failure for a failed check, validate-build::apply-fix for the chosen strategy, and re-runs the affected cargo-operations op."
    condition:
      type: and
      conditions[2]:
        - type: simple
          variable: is_review_mode
          operator: "!="
          value: true
        - type: simple
          variable: has_failures
          operator: ==
          value: true
  - id: scan-commit-signatures-for-strategic
    name: Scan PR commit signatures (preflight)
    description: "In target_path, resolve MERGE_BASE against the default branch (try origin/main, origin/master, main, master in order). Run git log --format='%h %G? %s' MERGE_BASE..HEAD. If ANY line has %G? of N (no signature) or B (bad), set unsigned_commits_in_pr to true and populate unsigned_commit_list_summary with a concise list of affected commits; otherwise set unsigned_commits_in_pr to false and clear the summary. Review mode uses the same branch/PR under review. This runs before strategic-review so the orchestrator can resolve the unsigned-commits checkpoint with accurate state."
    actions[2]:
      - action: set
        target: unsigned_commits_in_pr
        message: "true if any commit in range has G? N or B; false if all commits good (G/U) or range empty"
      - action: set
        target: unsigned_commit_list_summary
        message: "Comma-separated short lines (hash + subject) for unsigned/bad commits, or empty string if none"
loops[1]:
  - id: fix-revalidate-cycle
    name: Fix and Revalidate Cycle
    type: doWhile
    condition:
      type: simple
      variable: has_failures
      operator: "=="
      value: true
    maxIterations: 10
    steps[3]:
      - id: analyze-failure
        name: Analyze Failure Root Cause
        description: "validate-build::analyze-failure(check_id: {failed_check_id}, diagnostics: {failed_check_diagnostics}, target_path: {target_path})"
      - id: apply-fix
        name: Apply Fix
        description: "validate-build::apply-fix(check_id: {failed_check_id}, fix_strategy: {fix_strategy})"
      - id: revalidate
        name: Re-run Validation
        description: "Re-run the failed check by invoking the matching cargo-operations operation (cargo-operations::test for run-tests, ::check for verify-build, ::fmt-check for check-format, ::clippy for check-lint), then re-aggregate via validate-build::aggregate-results and update has_failures from the new validation_results."
transitions[1]:
  - to: strategic-review
    isDefault: true
exitActions[1]{action,message}:
  message,README PROGRESS: Update planning folder README.md — mark validation results as ✅ Complete.
outcome[2]:
  - All tests passing
  - Build successful
context_to_preserve[6]:
  - test_results - Test execution results
  - build_status - Build success/failure status
  - validation_passed - Whether all validation checks passed
  - unsigned_commits_in_pr - Whether unsigned/bad GPG commits exist in PR range
  - unsigned_commit_list_summary - Summary for strategic-review checkpoint messaging
  - resign_unsigned_commits_requested - Filled when user opts to re-sign at strategic review
