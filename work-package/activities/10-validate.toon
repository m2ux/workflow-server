id: validate
version: 3.1.0
name: Verify & Validate Design
description: "Validate the implementation against tests, build, format, and lint checks."
problem: User needs to validate the implementation passes all tests
recognition[3]:
  - validate implementation
  - run tests
  - verify build
required: true
estimatedTime: 15-30m
techniques:
  supporting[1]:
    - "variable-binding"
steps[5]:
  - id: preflight
    name: Toolchain preflight
    technique: cargo-operations::preflight
    when: "project_type == 'rust-substrate'"
    actions[1]:
      - action: validate
        target: "missing_prerequisites.length == 0"
        message: "Install missing toolchain prerequisites before validation: {missing_prerequisites}"
  - id: run-suite
    name: Run validation suite
    technique: cargo-operations::run-suite
    technique_args:
      scope: "--workspace"
    when: "project_type == 'rust-substrate'"
  - id: document-failures
    name: Document Failures as Findings
    technique: findings-classification
    condition:
      type: simple
      variable: is_review_mode
      operator: "=="
      value: true
  - id: assess-test-coverage
    name: Assess Test Coverage
    technique: review-test-suite
    condition:
      type: simple
      variable: is_review_mode
      operator: "=="
      value: true
  - id: fix-failures
    name: Fix any failures
    condition:
      type: and
      conditions[2]:
        - type: simple
          variable: is_review_mode
          operator: "!="
          value: true
        - type: simple
          variable: "validation_results.validation_passed"
          operator: ==
          value: false
loops[1]:
  - id: fix-revalidate-cycle
    name: Fix and Revalidate Cycle
    type: doWhile
    condition:
      type: simple
      variable: "validation_results.validation_passed"
      operator: "=="
      value: false
    maxIterations: 10
    steps[3]:
      - id: analyze-failure
        name: Analyze Failure Root Cause
        technique: validate-build::analyze-failure
        technique_args:
          check_id: "{validation_results.first_failure.check_id}"
          diagnostics: "{validation_results.first_failure.diagnostics}"
      - id: apply-fix
        name: Apply Fix
        technique: validate-build::apply-fix
        technique_args:
          check_id: "{validation_results.first_failure.check_id}"
      - id: revalidate
        name: Re-run Validation
        technique: cargo-operations::run-suite
        technique_args:
          scope: "--workspace"
transitions[1]:
  - to: strategic-review
    isDefault: true
exitActions[1]{action,message}:
  message,README PROGRESS: Update planning folder README.md — mark validation results as ✅ Complete.
outcome[2]:
  - All tests passing
  - Build successful
context_to_preserve[1]:
  - validation_results - Aggregate validation envelope (per-check statuses + validation_passed)
