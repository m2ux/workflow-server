id: validate
version: 3.2.0
name: Verify & Validate Design
description: "Validate the implementation against tests, build, format, and lint checks."
required: true
steps[6]:
  - kind: technique
    id: preflight
    technique: cargo-operations::preflight
    when: "project_type == 'rust-substrate'"
    actions[1]:
      - action: validate
        target: "missing_prerequisites.length == 0"
        message: "Install missing toolchain prerequisites before validation: {missing_prerequisites}"
  - kind: technique
    id: run-suite
    technique:
      name: cargo-operations::run-suite
      inputs:
        build_scope: "--workspace"
    when: "project_type == 'rust-substrate'"
  - kind: technique
    id: document-failures
    technique: findings-classification
    condition:
      type: simple
      variable: is_review_mode
      operator: "=="
      value: true
  - kind: technique
    id: assess-test-coverage
    technique: review-test-suite
    condition:
      type: simple
      variable: is_review_mode
      operator: "=="
      value: true
  - kind: action
    id: fix-failures
    condition:
      type: and
      conditions[2]:
        - type: simple
          variable: is_review_mode
          operator: "!="
          value: true
        - type: simple
          variable: "validation_results.validation_passed"
          operator: ==
          value: false
    actions[0]:
  - kind: loop
    id: fix-revalidate-cycle
    name: Fix and Revalidate Cycle
    loopType: doWhile
    condition:
      type: simple
      variable: "validation_results.validation_passed"
      operator: "=="
      value: false
    maxIterations: 10
    steps[3]:
      - kind: technique
        id: analyze-failure
        technique:
          name: validate-build::analyze-failure
          inputs:
            check_id: "{validation_results.first_failure.check_id}"
            failure_diagnostics: "{validation_results.first_failure.diagnostics}"
      - kind: technique
        id: apply-fix
        technique:
          name: validate-build::apply-fix
          inputs:
            check_id: "{validation_results.first_failure.check_id}"
      - kind: technique
        id: revalidate
        technique:
          name: cargo-operations::run-suite
          inputs:
            build_scope: "--workspace"
transitions[1]:
  - to: strategic-review
    isDefault: true
outcome[2]:
  - All tests passing
  - Build successful
