id: validate-build
version: 1.4.0
capability: Validate implementation through test execution, build verification, and lint checking

description: "Runs the full validation suite: tests, build verification, format check, and lint check. Analyzes failures, applies fixes, and re-runs until all pass. Provides observable results — does not ask user about test/build outcomes. MANDATORY: validation steps for Rust/Substrate projects are performed by invoking cargo-operations skill operations directly. This skill never spawns a shell to run a cargo subcommand; it delegates to cargo-operations."

inputs[2]:
  - id: project-type
    description: "Project type (rust-substrate, other) — determines commands"
  - id: target-submodule
    description: "Target submodule path (e.g., midnight-node, midnight-ledger)"

precondition[1]:
  - "Load the cargo-operations skill before executing any protocol step: get_skill skill_id: 'cargo-operations', workflow_id: 'work-package'. All Rust/Substrate validation actions in this skill are delegated to its operations."

protocol:
  run-tests[3]:
    - "Rust/Substrate: invoke cargo-operations.test (scope='--workspace'). Other project types: run the equivalent test command for the project."
    - Observe and record results
    - Do not ask user about test outcomes — results are observable
  verify-build[2]:
    - "Rust/Substrate dev/check pass: invoke cargo-operations.check (scope='--workspace'). Rust/Substrate release pass producing runtime wasm or final binary: invoke cargo-operations.build-release. Other project types: run the equivalent build command for the project."
    - Observe and record result
  check-format[3]:
    - "Rust/Substrate: invoke cargo-operations.fmt-check (scope='--all'). Matches the exact CI command and checks ALL workspace members. Other project types: run the equivalent canonical formatting check."
    - "Formatting diffs are treated as failures."
    - Record any formatting diffs as failures
  check-lint[2]:
    - "Rust/Substrate: invoke cargo-operations.clippy (scope='--workspace'). Other project types: run the equivalent linter."
    - Observe and record results
  fix-failures[4]:
    - If any check failed — analyze root cause
    - Apply fix
    - Re-run failed check
    - Repeat until all pass

output[1]:
  - id: validation-results
    description: "Validation outcomes from tests, build, and lint"
    components:
      test_results: "Test execution results (pass/fail, output)"
      build_status: "Build success or failure"
      lint_results: "Linter output and any issues"
      validation_passed: "Boolean — all checks passed"

rules:
  no-duplicate-review: "Test suite quality was already reviewed in post-impl-review — this activity validates execution only"
  delegate-to-cargo-operations: "Rust/Substrate validation actions in this skill are delegated to cargo-operations operations (cargo-operations.test, .check, .build-release, .clippy, .fmt-check). This skill does not invoke cargo directly — that responsibility lives entirely in cargo-operations, where the resource budget is encoded."

errors:
  persistent_failure:
    cause: Tests fail repeatedly after fixes
    recovery: Present analysis to user for guidance
  build_environment:
    cause: Missing dependencies or toolchain issues
    recovery: Check project setup instructions
